{
    "name": "edd-war/laravel-multitenencia",
    "description": "Hace que tu API REST o tu Laravel sean utilizables por multiples inquilinos",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "edd-war",
        "laravel-multitenencia"
    ],
    "homepage": "https://github.com/edd-war/laravel-multitenencia",
    "authors": [
        {
            "name": "Eduardo Arroyo Morales",
            "email": "digiespirit.1807@gmail.com",
			"homepage": "https://github.com/Edd-war",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/support": "^13.21.1",
        "spatie/laravel-package-tools": "^1.93.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.10.0",
        "laravel/octane": "2.18.0",
        "laravel/pint": "^1.29.3",
        "laravel/serializable-closure": "2.0.15",
        "mockery/mockery": "^1.6.12",
        "orchestra/testbench": "11.1.0",
        "pestphp/pest": "4.7.5",
        "phpstan/extension-installer": "^1.4.3",
        "spatie/valuestore": "^1.3.3"
    },
    "autoload": {
        "psr-4": {
            "Eddwar\\Multitenencia\\": "src",
            "Eddwar\\Multitenencia\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eddwar\\Multitenencia\\Tests\\": "tests"
        },
        "classmap": [
            "tests/database/migrations/propietario",
            "tests/database/migrations"
        ]
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --coverage-html",
        "format": "vendor/bin/pint --preset laravel --ansi",
        "analyse": "vendor/bin/phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1024M --ansi"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eddwar\\Multitenencia\\Providers\\MultitenenciaServiceProvider"
            ],
            "aliases": {
                "Multitenencia": "Eddwar\\Multitenencia\\MultitenenciaFacade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
